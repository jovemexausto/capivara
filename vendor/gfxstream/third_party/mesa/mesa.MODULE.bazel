git_repository = use_repo_rule("@bazel_tools//tools/build_defs/repo:git.bzl", "git_repository")

git_repository(
    name = "drm",
    build_file = "//third_party/mesa:BUILD.drm.bazel",
    # TODO: b/414448658 - gitlab.freedesktop.org having an outage
    #commit = "998d2a2e81e11043781672494dc3d294c1ecfce0",
    #remote = "https://gitlab.freedesktop.org/mesa/drm.git",
    commit = "f241f822cebbd681e46201b16685a827eb024736",
    dev_dependency = True,
    remote = "https://android.googlesource.com/platform/external/libdrm.git",
)

git_repository(
    name = "mesa",
    build_file = "//third_party/mesa:BUILD.mesa.bazel",
    commit = "93476c62994245aba4e3fef4acaaad90c91a61be",
    dev_dependency = True,
    patch_args = [
        "-p1",
        "--ignore-whitespace",
    ],
    patches = [
        "//third_party/mesa:PATCH.0001_disable_vk_envvar_modification_for_testing.patch",
    ],
    remote = "https://android.googlesource.com/platform/external/mesa3d.git",
)

mesa_crate_deps = use_extension(
    "@rules_rust//crate_universe:extensions.bzl",
    "crate",
    dev_dependency = True,
)
mesa_crate_deps.spec(
    package = "cfg-if",
    version = "1.0.0",
)
mesa_crate_deps.spec(
    package = "thiserror",
    version = "2.0.11",
)
mesa_crate_deps.spec(
    package = "libc",
    version = "0.2.116",
)
mesa_crate_deps.spec(
    package = "log",
    version = "0.4",
)
mesa_crate_deps.spec(
    package = "remain",
    version = "0.2",
)
mesa_crate_deps.spec(
    package = "thiserror",
    version = "1.0.23",
)
mesa_crate_deps.spec(
    features = ["derive"],
    package = "zerocopy",
    version = "0.8.13",
)
mesa_crate_deps.spec(
    features = [
        "event",
        "fs",
        "mm",
        "net",
        "param",
        "pipe",
        "thread",
        "use-libc",
        "use-libc-auxv",
        "libc_errno",
    ],
    package = "rustix",
    version = "1.0.7",
)
mesa_crate_deps.from_specs(
    name = "mesa_crate_deps",
)
use_repo(mesa_crate_deps, "mesa_crate_deps")
