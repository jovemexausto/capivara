CONFIG_VIRTIO_MMIO=y
CONFIG_CRYPTO_USER=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_UDMABUF=y
# Codec2 (media.swcodec) builds its platform allocator store at service start,
# which constructs C2AllocatorIon -> BufferAllocator backed by a dmabuf heap.
# The base gki_defconfig leaves DMABUF_HEAPS_SYSTEM unset and ION is gone in
# 6.12, so /dev/dma_heap/system and /dev/ion are both absent -> C2AllocatorIon
# SIGSEGVs -> media.swcodec dies -> any MediaCodec user (system_server during
# boot, scrcpy's H.264 encoder) aborts. Enable the system heap so a dmabuf
# allocator exists.
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
